{
  "manifest_version": 3,
  "name": "Quick Lookup",
  "version": "2.0",
  "description": "Open a dictionary page when selecting a word and pressing ALT.",
  "permissions": ["tabs", "storage"],
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "ldoce-lookup@example.com"
    }
  }
}