{
  "manifest_version": 3,
  "name": "Quick Lookup",
  "version": "2.0",
"description": "Instantly open a dictionary lookup for selected text using a keyboard shortcut.",
  "permissions": [
    "storage"
  ],
  "background": {
    "scripts": [
      "background.js"
    ],
    "type": "module"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "quick-lookup@example.com",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "icons": {
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": "icons/icon-128.png"
  }
}